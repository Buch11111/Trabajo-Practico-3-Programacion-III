            }
          }
        },
        {
          "name": "GET - Álbum por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/albumes/{id}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "albumes", "{{albumId}}"]
            }
          }
        },
        {
          "name": "POST - Crear álbum",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Nuevo Álbum\",\n  \"fechaLanzamiento\": \"2024-01-15\",\n  \"artistaId\": \"{{artistaId}}\",\n  \"productoraId\": \"{{productoraId}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/albumes",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "albumes"]
            },
            "description": "Crea un nuevo álbum. El ID se genera automáticamente. Valida que el artista y la productora referenciados existan (400 si no)."
          }
        },
        {
          "name": "PUT - Actualizar álbum",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"titulo\": \"Álbum Actualizado\",\n  \"fechaLanzamiento\": \"2024-06-01\",\n  \"artistaId\": \"{{artistaId}}\",\n  \"productoraId\": \"{{productoraId}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/albumes/{id}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "albumes", "{{albumId}}"]
            },
            "description": "Actualiza todos los datos de un álbum existente. Valida que el artista y la productora referenciados existan (400 si no)."
          }
        },
        {
          "name": "DELETE - Eliminar álbum",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/api/albumes/{id}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "albumes", "{{albumId}}"]
            },
            "description": "Elimina un álbum por su UUID. Retorna 204 No Content si es exitoso, 404 si no existe."
          }
        }
      ]
    },
